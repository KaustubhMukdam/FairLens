.env
.env.local
.env.*.local
service-account.json
backend/service-account.json
*.pem
*.p12
*.key

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# --- Virtual Environments ---
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# --- Scratch / Test scripts ---
backend/scratch_test.py
backend/response.json
backend/scratch_output.txt
backend/test_e2e.py
tests/

# --- Node / Frontend ---
node_modules/
dist-ssr/
*.local
frontend/dist/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- OS & Editor ---
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/
*.swp
